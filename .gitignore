# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
kaggle.json
*.key
*.pem

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/
.venv/
venv/
*.pyc

